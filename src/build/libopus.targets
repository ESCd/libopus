<Project>

  <PropertyGroup>
    <!-- NOTE: disable static linking if no runtime identifier is specified -->
    <LibOpusStaticLinking Condition=" '$(RuntimeIdentifier)' == '' ">false</LibOpusStaticLinking>

    <!-- NOTE: enable static linking if AOT publishing is enabled and a runtime identifier is specified -->
    <LibOpusStaticLinking Condition=" '$(LibOpusStaticLinking)' == 'none' AND '$(PublishAot)' == 'true' AND '$(RuntimeIdentifier)' != '' ">true</LibOpusStaticLinking>

    <!-- NOTE: disable runtime linking if static linking is enabled -->
    <LibOpusRuntimeLinking Condition=" '$(LibOpusStaticLinking)' == 'true' ">false</LibOpusRuntimeLinking>
  </PropertyGroup>

  <ItemGroup Condition=" '$(LibOpusRuntimeLinking)' == 'true' ">
    <Content Include="$(LibOpusDirectory)\shared\**\*.*" Visible="$(LibOpusItemsVisible)" Condition=" '$(Configuration)' == 'Debug' OR '$(RuntimeIdentifier)' == '' ">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>runtimes\%(RecursiveDir)\%(Filename)%(Extension)</Link>
      <TargetPath>runtimes\%(RecursiveDir)\%(Filename)%(Extension)</TargetPath>
    </Content>

    <Content Include="$(LibOpusDirectory)\shared\$(RuntimeIdentifier)\native\*.*" Visible="$(LibOpusItemsVisible)" Condition=" '$(RuntimeIdentifier)' != '' ">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>%(Filename)%(Extension)</Link>
      <TargetPath>%(Filename)%(Extension)</TargetPath>
    </Content>
  </ItemGroup>

  <ItemGroup Condition=" '$(LibOpusStaticLinking)' == 'true' AND '$(RuntimeIdentifier)' != '' ">
    <DirectPInvoke Include="opus;libopus" />

    <NativeLibrary Include="$(LibOpusDirectory)\static\$(RuntimeIdentifier)\native\*.*" />
  </ItemGroup>

  <Target Name="_PrepareLibOpusBuild" AfterTargets="PrepareForBuild">
    <Error Text="A RuntimeIdentifier must be specified when static linking is enabled." Condition=" '$(LibOpusStaticLinking)' == 'true' AND '$(RuntimeIdentifier)' == '' " />
    <Warning Text="LibOpusRuntimeLinking=true: runtime linking should not be enabled when static linking is enabled." Condition=" '$(LibOpusRuntimeLinking)' == 'true' AND '$(LibOpusStaticLinking)' == 'true' " />
  </Target>

</Project>