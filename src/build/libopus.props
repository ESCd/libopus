<Project>

  <PropertyGroup>
    <LibOpusDirectory>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)\..'))</LibOpusDirectory>
    <LibOpusEnableRuntimeLinking Condition=" '$(LibOpusEnableRuntimeLinking)' == '' ">true</LibOpusEnableRuntimeLinking>
    <LibOpusEnableStaticLinking Condition=" '$(LibOpusEnableStaticLinking)' == '' AND '$(PublishAot)' == 'true' AND '$(RuntimeIdentifier)' != '' ">true</LibOpusEnableStaticLinking>
  </PropertyGroup>

</Project>