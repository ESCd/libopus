<Project>

  <PropertyGroup>
    <LibOpusDirectory>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)\..'))</LibOpusDirectory>
    <LibOpusItemsVisible Condition=" '$(LibOpusItemsVisible)' == '' ">false</LibOpusItemsVisible>
    <LibOpusRuntimeLinking Condition=" '$(LibOpusRuntimeLinking)' == '' ">true</LibOpusRuntimeLinking>
    <LibOpusStaticLinking Condition=" '$(LibOpusStaticLinking)' == '' ">none</LibOpusStaticLinking>
    <LibOpusStaticLinking Condition=" '$(LibOpusStaticLinking)' == 'none' AND '$(PublishAot)' == 'true' AND '$(RuntimeIdentifier)' != '' ">true</LibOpusStaticLinking>
  </PropertyGroup>

</Project>